{
  "name": "cumber-storm",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=@cumberstorm/core && turbo run build --filter=@cumberstorm/html-reporter",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "src/*"
  ]
}
