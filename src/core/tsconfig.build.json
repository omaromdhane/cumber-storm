{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "paths": {
      "@/*": ["./*"],
      "@cumberstorm/reporting": ["../reporting/dist"],
      "@cumberstorm/reporting/*": ["../reporting/dist/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
