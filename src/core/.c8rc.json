{
  "all": true,
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "dist/**",
    "node_modules/**",
    "src/**/types.ts",
    "src/**/index.ts"
  ],
  "reporter": ["text", "html", "lcov"],
  "report-dir": "./coverage",
  "check-coverage": false,
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80
}
